{
  "store.custom#product-tabs": {
    "blocks": ["flex-layout.row#section-title", "tab-layout#products"]
  },

  "flex-layout.row#section-title": {
    "title": "Título Nuestros Productos",
    "children": ["rich-text#section-title"],
    "props": {
      "blockClass": "sectionTitle",
      "fullWidth": true,
      "horizontalAlign": "center"
    }
  },

  "rich-text#section-title": {
    "title": "Texto Título Productos",
    "props": {
      "text": "Nuestros Productos",
      "blockClass": "sectionTitle",
      "textAlignment": "CENTER"
    }
  },

  "tab-layout#products": {
    "title": "Layout de Tabs de Productos",
    "children": ["tab-list#products", "tab-content#products"],
    "props": {
      "blockClass": "productsTab"
    }
  },

  "tab-list#products": {
    "title": "Lista de Tabs",
    "children": [
      "tab-list.item#all",
      "tab-list.item#audio",
      "tab-list.item#wearables",
      "tab-list.item#computers"
    ],
    "props": {
      "blockClass": "productsTabList"
    }
  },

  "tab-list.item#all": {
    "title": "Tab Todos",
    "props": {
      "tabId": "all",
      "label": "Todos",
      "defaultActiveTab": true,
      "blockClass": "tabButton"
    }
  },

  "tab-list.item#audio": {
    "title": "Tab Audio",
    "props": {
      "tabId": "audio",
      "label": "Audio",
      "blockClass": "tabButton"
    }
  },

  "tab-list.item#wearables": {
    "title": "Tab Wearables",
    "props": {
      "tabId": "wearables",
      "label": "Wearables",
      "blockClass": "tabButton"
    }
  },

  "tab-list.item#computers": {
    "title": "Tab Computadoras",
    "props": {
      "tabId": "computers",
      "label": "Computadoras",
      "blockClass": "tabButton"
    }
  },

  "tab-content#products": {
    "title": "Contenido de Tabs",
    "children": [
      "tab-content.item#all",
      "tab-content.item#audio",
      "tab-content.item#wearables",
      "tab-content.item#computers"
    ],
    "props": {
      "blockClass": "productsTabContent"
    }
  },

  "tab-content.item#all": {
    "title": "Contenido Tab Todos",
    "props": {
      "tabId": "all"
    },
    "children": ["list-context.product-list#all"]
  },

  "tab-content.item#audio": {
    "title": "Contenido Tab Audio",
    "props": {
      "tabId": "audio"
    },
    "children": ["list-context.product-list#audio"]
  },

  "tab-content.item#wearables": {
    "title": "Contenido Tab Wearables",
    "props": {
      "tabId": "wearables"
    },
    "children": ["list-context.product-list#wearables"]
  },

  "tab-content.item#computers": {
    "title": "Contenido Tab Computadoras",
    "props": {
      "tabId": "computers"
    },
    "children": ["list-context.product-list#computers"]
  },

  "list-context.product-list#all": {
    "title": "Lista Productos Todos",
    "props": {
      "maxItems": 4
    },
    "blocks": ["product-summary.shelf#tab-product"],
    "children": ["slider-layout#products"]
  },

  "list-context.product-list#audio": {
    "title": "Lista Productos Audio",
    "props": {
      "collection": "123",
      "maxItems": 4
    },
    "blocks": ["product-summary.shelf#tab-product"],
    "children": ["slider-layout#products"]
  },

  "list-context.product-list#wearables": {
    "title": "Lista Productos Wearables",
    "props": {
      "collection": "124",
      "maxItems": 4
    },
    "blocks": ["product-summary.shelf#tab-product"],
    "children": ["slider-layout#products"]
  },

  "list-context.product-list#computers": {
    "title": "Lista Productos Computadoras",
    "props": {
      "collection": "125",
      "maxItems": 4
    },
    "blocks": ["product-summary.shelf#tab-product"],
    "children": ["slider-layout#products"]
  },

  "product-summary.shelf#tab-product": {
    "title": "Tarjeta de Producto Tabs",
    "children": [
      "discount-flag",
      "product-summary-image#tab-product",
      "product-summary-name#tab-product",
      "product-rating-summary#tab-product",
      "flex-layout.row#product-prices-tab",
      "add-to-cart-button#tab-product"
    ],
    "props": {
      "blockClass": "tabProduct"
    }
  },

  "product-summary-image#tab-product": {
    "title": "Imagen Producto Tabs",
    "props": {
      "displayMode": "product-summary",
      "blockClass": "tabProductImage",
      "showBadge": false
    }
  },

  "product-summary-name#tab-product": {
    "title": "Nombre Producto Tabs",
    "props": {
      "blockClass": "tabProductName",
      "tag": "h3"
    }
  },

  "product-rating-summary#tab-product": {
    "title": "Calificación Producto Tabs",
    "props": {
      "blockClass": "tabProductRating"
    }
  },

  "flex-layout.row#product-prices-tab": {
    "title": "Precio Producto Tabs",
    "children": ["product-summary-price"],
    "props": {
      "blockClass": "productPrices",
      "colGap": 2,
      "preventHorizontalStretch": true,
      "horizontalAlign": "left"
    }
  },

  "slider-layout#products": {
    "title": "Slider de Productos Tabs",
    "props": {
      "itemsPerPage": { "desktop": 4, "tablet": 2, "mobile": 1 },
      "showPaginationDots": "always",
      "showNavigationArrows": "always",
      "usePagination": true,
      "gap": "ph4",
      "fullWidth": true,
      "blockClass": "productsSlider"
    }
  },

  "add-to-cart-button#tab-product": {
    "title": "Botón Comprar Tabs",
    "props": {
      "text": "Comprar",
      "blockClass": "buyButton"
    }
  }
}
